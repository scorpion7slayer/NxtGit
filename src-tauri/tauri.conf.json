{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "NxtGit",
    "version": "1.0.8",
    "identifier": "com.scorpion7slayer.nxtgit",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "macOSPrivateApi": true,
        "security": {
            "csp": "default-src 'self'; connect-src 'self' https: http://localhost:* http://127.0.0.1:*; script-src 'self' 'unsafe-inline' https: blob:; style-src 'self' 'unsafe-inline' https:; img-src 'self' https: data: blob:; font-src 'self' https: data: blob:; media-src 'self' https: data: blob:; frame-src 'self' https: blob: data:; worker-src 'self' https: blob:"
        },
        "windows": [
            {
                "label": "main",
                "fullscreen": false,
                "resizable": true,
                "title": "NxtGit",
                "width": 1400,
                "height": 900,
                "minWidth": 1200,
                "minHeight": 700,
                "transparent": true,
                "decorations": true,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true,
                "acceptFirstMouse": true
            }
        ]
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "category": "DeveloperTool",
        "copyright": "MIT",
        "windows": {
            "wix": {
                "version": "1.0.8.0"
            }
        },
        "macOS": {
            "frameworks": [],
            "minimumSystemVersion": "14.0"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/scorpion7slayer/NxtGit/releases/latest/download/latest.json"
            ],
            "pubkey": "__TAURI_SIGNING_PUBLIC_KEY__"
        }
    }
}
