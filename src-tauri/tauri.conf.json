{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "NxtGit",
    "version": "1.0.0",
    "identifier": "com.scorpion7slayer.nxtgit",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "macOSPrivateApi": true,
        "security": {
            "csp": "default-src 'self'; connect-src 'self' https://api.github.com https://api.githubcopilot.com https://api.openrouter.ai https://openrouter.ai https://api.anthropic.com https://api.openai.com https://api.moonshot.cn https://api.kilocode.ai https://api.minimax.chat http://localhost:* http://127.0.0.1:* https://ollama.com https://www.githubstatus.com https://au.githubstatus.com https://eu.githubstatus.com https://jp.githubstatus.com https://us.githubstatus.com https://github.blog https://codewiki.google; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:"
        },
        "windows": [
            {
                "label": "main",
                "fullscreen": false,
                "resizable": true,
                "title": "NxtGit",
                "width": 1400,
                "height": 900,
                "minWidth": 1200,
                "minHeight": 700,
                "transparent": true,
                "decorations": true,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true,
                "acceptFirstMouse": true
            }
        ]
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "category": "DeveloperTool",
        "copyright": "MIT",
        "macOS": {
            "frameworks": [],
            "minimumSystemVersion": "14.0"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/scorpion7slayer/NxtGit/releases/latest/download/latest.json"
            ],
            "pubkey": "__TAURI_SIGNING_PUBLIC_KEY__"
        }
    }
}
