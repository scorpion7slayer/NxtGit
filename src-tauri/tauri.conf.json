{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NxtGit",
  "version": "0.1.0",
  "identifier": "com.scorpion7slayer.nxtgit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.github.com https://api.openrouter.ai https://openrouter.ai; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:;"
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "NxtGit",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "category": "DeveloperTool",
    "copyright": "MIT",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "14.0",
      "license": "MIT"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
